{
  "name": "redis-scan-manager",
  "version": "1.0.0",
  "type": "module",
  "description": "High-performance Redis secondary index manager with hash sharding",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test:func": "npm run build && node test/test_functional.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "redis",
    "index",
    "secondary-index",
    "sharding"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "esbuild": "^0.27.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ioredis": "^5.9.2"
  }
}
